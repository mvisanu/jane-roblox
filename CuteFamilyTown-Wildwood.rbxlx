			{ Action = "PaintHome", Target = 1, Reward = 60, Description = "Choose a colour for your cottage", DescriptionThai = "เลือกสีให้บ้านของคุณ", Hint = "Open Home and tap a color swatch.", HintThai = "เปิดเมนูบ้าน แล้วแตะช่องสีที่ชอบ" },
