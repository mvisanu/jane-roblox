local welcomeTitle = Components.label(welcomeCard, "Welcome to Family Town!", UDim2.new(1, -40, 0, 70), UDim2.fromOffset(20, 22), 28, true)
welcomeTitle.TextColor3 = Theme.Colors.PinkDark
welcomeTitle.TextXAlignment = Enum.TextXAlignment.Center
local welcomeText = Components.label(
	welcomeCard,
	"1. Your home and garden are waiting.\n\n2. Care for Mochi and serve cafe guests.\n\n3. Earn coins, decorate, and explore together!",
	UDim2.new(1, -56, 0, 190),
