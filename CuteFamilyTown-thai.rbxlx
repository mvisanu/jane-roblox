	Bed = { DisplayName = "Cloud Bed", DisplayNameThai = "เตียงก้อนเมฆ", Price = 150, Color = Color3.fromRGB(190, 220, 255), Kind = "Bed" },
	Plant = { DisplayName = "Happy Plant", DisplayNameThai = "ต้นไม้อารมณ์ดี", Price = 50, Color = Color3.fromRGB(122, 199, 139), Kind = "Plant" },
