	Park = Vector3.new(0, 4, 130),
	Lake = Vector3.new(0, 4, 155),
	Beach = Vector3.new(155, 4, 0),
	Forest = Vector3.new(-155, 4, 0),
}

return table.freeze(Config)
]]></string>
