Catalog.SeedOrder = { "Daisy", "Tulip", "Lavender" }

Catalog.Furniture = {
	Chair = { DisplayName = "Cozy Chair", DisplayNameThai = "เก้าอี้แสนสบาย", Price = 75, Color = Color3.fromRGB(255, 182, 193), Kind = "Chair" },
	Lamp = { DisplayName = "Star Lamp", DisplayNameThai = "โคมไฟดาว", Price = 60, Color = Color3.fromRGB(255, 231, 150), Kind = "Lamp" },
