local toastSequence = 0
local function showToast(message, good)
	if type(message) ~= "string" or message == "" or message == "Ready" then
		return
	end
	toastSequence += 1
	local sequence = toastSequence
	toast.Text = message
	toast.BackgroundColor3 = good == false and Theme.Colors.Red or Theme.Colors.Ink
	toast.Visible = true
	TweenService:Create(toast, TweenInfo.new(0.18), { BackgroundTransparency = 0.08, TextTransparency = 0 }):Play()
	task.delay(2.6, function()
		if toastSequence == sequence and toast.Parent then
			local hide = TweenService:Create(toast, TweenInfo.new(0.2), { BackgroundTransparency = 1, TextTransparency = 1 })
			hide:Play()
			hide.Completed:Wait()
			if toastSequence == sequence then
				toast.Visible = false
			end
		end
	end)
end

local renderMenu
local function applyState(newState)
	if type(newState) ~= "table" then
		return
	end
	state = newState
	loading.Visible = false
	coinsLabel.Text = string.format("Coins  %d", state.Coins or 0)
	local daily = state.Daily or {}
	giftButton.Text = daily.CanClaim
		and bilingual("DAILY GIFT!", "รับของขวัญ!")
		or bilingual(string.format("STREAK %d", daily.Streak or 0), string.format("ต่อเนื่อง %d วัน", daily.Streak or 0))
	giftButton.BackgroundColor3 = daily.CanClaim and Theme.Colors.Yellow or Theme.Colors.Mint
	local quest = daily.Quest
	if quest then
		local doneText = quest.Completed and "  DONE!" or ""
		questLabel.Text = string.format("TODAY: %s  %d/%d%s", quest.Description, quest.Progress, quest.Target, doneText)
	end
	if panel.Visible and renderMenu then
		renderMenu(currentMenu)
	end
	if state.Settings and not state.Settings.Onboarded then
		onboarding.Visible = true
	end
end

local function invoke(action, payload, silent)
	if requestBusy and not silent then
		return
	end
	if not silent then
		requestBusy = true
	end
	task.spawn(function()
		local success, response = pcall(function()
			return requestRemote:InvokeServer(action, payload or {})
		end)
		if not silent then
			requestBusy = false
		end
		if success and type(response) == "table" then
			if response.state then
				applyState(response.state)
			end
			if not silent then
				showToast(response.message, response.ok)
			end
		elseif not silent then
			showToast("The town is taking a little nap. Try again!", false)
		end
	end)
end

local function resetBody()
	body:ClearAllChildren()
	local padding = Instance.new("UIPadding")
	padding.PaddingLeft = UDim.new(0, 4)
	padding.PaddingRight = UDim.new(0, 10)
	padding.PaddingTop = UDim.new(0, 4)
	padding.PaddingBottom = UDim.new(0, 16)
	padding.Parent = body
	local layout = Components.list(body, 10)
	return layout
end

local order = 0
local function nextOrder()
	order += 1
	return order
end

local function addHeading(text)
	local label = Components.label(body, text, UDim2.new(1, 0, 0, 34), nil, 19, true)
	label.LayoutOrder = nextOrder()
	label.TextColor3 = Theme.Colors.PinkDark
	return label
end

local function addText(text, height)
	local label = Components.label(body, text, UDim2.new(1, 0, 0, height or 44), nil, 16, false)
	label.LayoutOrder = nextOrder()
	label.TextColor3 = Theme.Colors.Muted
	label.TextYAlignment = Enum.TextYAlignment.Top
	return label
end

local function addButton(text, color, action, payload)
	local button = Components.button(body, text, color, function()
		invoke(action, payload)
	end)
	button.LayoutOrder = nextOrder()
	return button
end

local MENU_COLORS = {
	Home = Theme.Colors.Pink,
	Garden = Theme.Colors.Mint,
	Pet = Theme.Colors.Purple,
	Cafe = Theme.Colors.Yellow,
	Style = Theme.Colors.Blue,
	Map = Theme.Colors.Mint,
}

renderMenu = function(menu)
	if not state then
		return
	end
	currentMenu = menu
	panel.Visible = true
	panelTitle.Text = string.upper(menu == "Style" and "DRESS UP" or menu)
	order = 0
	resetBody()
	for name, button in pairs(navButtons) do
		button.BackgroundColor3 = name == menu and MENU_COLORS[name] or Theme.Colors.White
		button.TextColor3 = name == menu and Theme.Colors.White or Theme.Colors.Ink
	end

	if menu == "Home" then
		addHeading(string.format("Your %s home", state.Home.Paint))
		addText("Paint it, place cozy furniture, and make it yours.")
		addButton(bilingual("Paint my home", "ทาสีบ้านของฉัน"), Theme.Colors.Pink, "PaintHome", {})
		addHeading(string.format("Home box  (%d/%d placed)", #state.Home.Furniture, Config.MaxFurniture))
		if #state.Home.Furniture > 0 then
			addButton(bilingual("Pack away the last item", "เก็บของชิ้นล่าสุด"), Theme.Colors.Blue, "RemoveFurniture", {})
		end
		for _, itemId in ipairs(Catalog.FurnitureOrder) do
			local item = Catalog.Furniture[itemId]
			local owned = state.Home.OwnedFurniture[itemId] or 0
			local placed = 0
			for _, entry in ipairs(state.Home.Furniture) do
				if entry.Id == itemId then
					placed += 1
				end
			end
			if owned > placed then
				addButton(
					bilingual(
						string.format("Place %s (%d ready)", item.DisplayName, owned - placed),
						string.format("วาง%s (พร้อมใช้ %d ชิ้น)", item.DisplayNameThai, owned - placed)
					),
					item.Color,
					"PlaceFurniture",
					{ item = itemId }
				)
			end
		end
		addHeading("Furniture shop")
		for _, itemId in ipairs(Catalog.FurnitureOrder) do
			local item = Catalog.Furniture[itemId]
			addButton(
				bilingual(
					string.format("Buy %s - %d coins", item.DisplayName, item.Price),
					string.format("ซื้อ%s - %d เหรียญ", item.DisplayNameThai, item.Price)
				),
				Theme.Colors.Purple,
				"BuyFurniture",
				{ item = itemId }
			)
		end
	elseif menu == "Garden" then
		addHeading("Your flower patches")
		addText("Plant, water, wait a little, then pick flowers for coins.")
		for index, slot in ipairs(state.Garden.Slots) do
			if slot.State == "Empty" then
				addHeading(string.format("Patch %d is ready", index))
				local hasSeed = false
				for _, seedId in ipairs(Catalog.SeedOrder) do
					local count = state.Garden.Seeds[seedId] or 0
					if count > 0 then
						hasSeed = true
						local seed = Catalog.Seeds[seedId]
						addButton(
							bilingual(
								string.format("Plant %s (%d seeds)", seed.DisplayName, count),
								string.format("ปลูก%s (มี %d เมล็ด)", seed.DisplayNameThai, count)
							),
							seed.Color,
							"GardenPlant",
							{ slot = index, seed = seedId }
						)
					end
				end
				if not hasSeed then
					addText("Buy a seed below to use this patch.", 34)
				end
			elseif not slot.Watered then
				local seed = Catalog.Seeds[slot.Seed]
				addButton(
					bilingual(
						string.format("Patch %d: Water %s", index, seed.DisplayName),
						string.format("แปลง %d: รดน้ำ%s", index, seed.DisplayNameThai)
					),
					Theme.Colors.Blue,
					"GardenWater",
					{ slot = index }
				)
			elseif slot.Ready then
				local seed = Catalog.Seeds[slot.Seed]
				addButton(
					bilingual(
						string.format("Patch %d: Pick %s!", index, seed.DisplayName),
						string.format("แปลง %d: เก็บ%s!", index, seed.DisplayNameThai)
					),
					Theme.Colors.Yellow,
					"GardenHarvest",
					{ slot = index }
				)
			else
				local seed = Catalog.Seeds[slot.Seed]
				local seconds = math.ceil(slot.SecondsLeft or 0)
				addButton(
					bilingual(
						string.format("Patch %d: %s grows for %ds", index, seed.DisplayName, seconds),
						string.format("แปลง %d: %sโตอีก %d วินาที", index, seed.DisplayNameThai, seconds)
					),
					Theme.Colors.Purple,
					"GardenHarvest",
					{ slot = index }
				)
			end
		end
		addHeading("Seed basket")
		local prices = { Daisy = 15, Tulip = 25, Lavender = 40 }
		for _, seedId in ipairs(Catalog.SeedOrder) do
			local seed = Catalog.Seeds[seedId]
			local seedCount = state.Garden.Seeds[seedId] or 0
			addButton(
				bilingual(
					string.format("Buy %s seed - %d coins (have %d)", seed.DisplayName, prices[seedId], seedCount),
					string.format("ซื้อเมล็ด%s - %d เหรียญ (มี %d)", seed.DisplayNameThai, prices[seedId], seedCount)
				),
				seed.Color,
				"BuySeed",
				{ seed = seedId }
			)
		end
	elseif menu == "Pet" then
		addHeading(string.format("%s the %s - Level %d", state.Pet.Name, state.Pet.Species, state.Pet.Level))
		addText(string.format("Hunger: %d/100    Clean: %d/100\nLevel XP: %d/%d", state.Pet.Hunger, state.Pet.Cleanliness, state.Pet.XP, state.Pet.Level * 25), 58)
		addButton(bilingual("Give a snack - 5 coins", "ให้ขนม - 5 เหรียญ"), Theme.Colors.Pink, "PetFeed", {})
		addButton(bilingual("Play together", "เล่นด้วยกัน"), Theme.Colors.Purple, "PetPlay", {})
		addButton(bilingual("Bubble bath", "อาบน้ำฟองสบู่"), Theme.Colors.Blue, "PetBath", {})
		addButton(bilingual("Visit the Pet Shop", "ไปร้านสัตว์เลี้ยง"), Theme.Colors.Blue, "Teleport", { destination = "PetShop" })
	elseif menu == "Cafe" then
		if not state.Cafe.Unlocked then
			addHeading("Open your family cafe")
			addText("Serve friendly town guests and earn coins together.")
			addButton(
				bilingual(
					string.format("Open cafe - %d coins", Config.CafeUnlockCost),
					string.format("เปิดคาเฟ่ - %d เหรียญ", Config.CafeUnlockCost)
				),
				Theme.Colors.Pink,
				"CafeUnlock",
				{}
			)
		else
			addHeading(string.format("Family Cafe - Level %d", state.Cafe.Level))
			addText(string.format("You have served %d happy guests. Helpers: %d/3", state.Cafe.Served, state.Cafe.Staff or 0))
			addButton(bilingual("Make a cupcake and serve", "ทำคัพเค้กและเสิร์ฟ"), Theme.Colors.Pink, "CafeServe", {})
			local upgradeCost = state.Cafe.Level * 180
			addButton(
				bilingual(
					string.format("Upgrade cafe - %d coins", upgradeCost),
					string.format("อัปเกรดคาเฟ่ - %d เหรียญ", upgradeCost)
				),
				Theme.Colors.Mint,
				"CafeUpgrade",
				{}
			)
			if (state.Cafe.Staff or 0) < 3 then
				local helperCost = 250 + (state.Cafe.Staff or 0) * 200
				addButton(
					bilingual(
						string.format("Hire NPC helper - %d coins", helperCost),
						string.format("จ้างผู้ช่วย NPC - %d เหรียญ", helperCost)
					),
					Theme.Colors.Purple,
					"HireCafeStaff",
					{}
				)
			end
		end
		addButton(bilingual("Go to the Cafe", "ไปคาเฟ่"), Theme.Colors.Yellow, "Teleport", { destination = "Cafe" })
	elseif menu == "Style" then
		addHeading("Choose a happy outfit")
		local equipped = Catalog.Outfits[state.Wardrobe.Equipped] or Catalog.Outfits.Sunshine
		addText(string.format("Wearing: %s", equipped.DisplayName))
		for _, outfitId in ipairs(Catalog.OutfitOrder) do
			local outfit = Catalog.Outfits[outfitId]
			addButton(
				bilingual(string.format("Wear %s", outfit.DisplayName), string.format("ใส่ชุด%s", outfit.DisplayNameThai)),
				outfit.Torso,
				"EquipOutfit",
				{ outfit = outfitId }
			)
		end
	elseif menu == "Map" then
		addHeading("Where shall we go?")
		addText("Tap a place to travel there safely.")
		addButton(bilingual("My Home", "บ้านของฉัน"), Theme.Colors.Pink, "Teleport", { destination = "Home" })
		for _, destination in ipairs({ "Town", "Cafe", "PetShop", "FlowerShop", "Playground", "School", "Park", "Lake", "Beach", "Forest" }) do
			local english = destination:gsub("(%l)(%u)", "%1 %2")
			addButton(bilingual(english, DESTINATION_THAI[destination]), Theme.Colors.Blue, "Teleport", { destination = destination })
		end
	end
end

for index, name in ipairs({ "Home", "Garden", "Pet", "Cafe", "Style", "Map" }) do
	local button = Instance.new("TextButton")
	button.Name = name
	button.AutoButtonColor = false
	button.BackgroundColor3 = Theme.Colors.White
	button.Size = UDim2.new(1 / 6, -9, 1, 0)
	button.Font = Enum.Font.GothamBold
	button.LayoutOrder = index
	button.Text = bilingual(string.upper(name), NAV_THAI[name])
	button.TextColor3 = Theme.Colors.Ink
	button.TextSize = 11
	button.TextWrapped = true
	button.Parent = nav
	Components.corner(button, Theme.SmallCorner)
	button.Activated:Connect(function()
		renderMenu(name)
	end)
	navButtons[name] = button
end

closeButton.Activated:Connect(function()
	panel.Visible = false
end)

giftButton.Activated:Connect(function()
	if state and state.Daily and state.Daily.CanClaim then
		invoke("ClaimDaily", {})
	else
		showToast("Come back tomorrow for another gift!")
	end
end)

startButton.Activated:Connect(function()
	onboarding.Visible = false
	invoke("FinishOnboarding", {})
	renderMenu("Home")
end)

stateChanged.OnClientEvent:Connect(applyState)
toastRemote.OnClientEvent:Connect(showToast)

invoke("GetState", {}, true)

task.spawn(function()
	while gui.Parent do
		task.wait(5)
		invoke("GetState", {}, true)
	end
end)
]]></string>
        </Properties>
      </Item>
      <Item class="Folder" referent="17">
        <Properties>
          <string name="Name">UI</string>
        </Properties>
        <Item class="ModuleScript" referent="18">
          <Properties>
            <string name="Name">Components</string>
            <string name="Source"><![CDATA[local TweenService = game:GetService("TweenService")

local Theme = require(script.Parent:WaitForChild("Theme"))
local Components = {}

function Components.corner(parent, radius)
	local corner = Instance.new("UICorner")
	corner.CornerRadius = radius or Theme.Corner
	corner.Parent = parent
	return corner
end

function Components.stroke(parent, color, thickness, transparency)
	local stroke = Instance.new("UIStroke")
	stroke.Color = color or Theme.Colors.White
	stroke.Thickness = thickness or 2
	stroke.Transparency = transparency or 0
	stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
	stroke.Parent = parent
	return stroke
end

function Components.shadow(parent)
	local shadow = Instance.new("ImageLabel")
	shadow.Name = "Shadow"
	shadow.AnchorPoint = Vector2.new(0.5, 0.5)
	shadow.BackgroundTransparency = 1
	shadow.Image = "rbxassetid://1316045217"
	shadow.ImageColor3 = Theme.Colors.Shadow
	shadow.ImageTransparency = 0.75
	shadow.Position = UDim2.fromScale(0.5, 0.54)
	shadow.ScaleType = Enum.ScaleType.Slice
	shadow.SliceCenter = Rect.new(10, 10, 118, 118)
	shadow.Size = UDim2.new(1, 24, 1, 24)
	shadow.ZIndex = math.max(0, parent.ZIndex - 1)
	shadow.Parent = parent
	return shadow
end

function Components.label(parent, text, size, position, textSize, bold)
	local label = Instance.new("TextLabel")
	label.BackgroundTransparency = 1
	label.Size = size
	label.Position = position or UDim2.fromOffset(0, 0)
	label.Font = bold and Enum.Font.GothamBold or Enum.Font.GothamMedium
	label.Text = text
	label.TextColor3 = Theme.Colors.Ink
	label.TextSize = textSize or 18
	label.TextWrapped = true
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.Parent = parent
	return label
end

function Components.button(parent, text, color, callback)
	local button = Instance.new("TextButton")
	button.AutoButtonColor = false
	button.BackgroundColor3 = color or Theme.Colors.Pink
	button.Size = UDim2.new(1, 0, 0, Theme.TouchHeight)
	button.Font = Enum.Font.GothamBold
	button.Text = text
	button.TextColor3 = Theme.Colors.White
	button.TextSize = 15
	button.TextWrapped = true
	button.Parent = parent
	Components.corner(button, Theme.SmallCorner)
	Components.stroke(button, Theme.Colors.White, 2, 0.45)

	button.MouseEnter:Connect(function()
		TweenService:Create(button, TweenInfo.new(0.12), { BackgroundColor3 = button.BackgroundColor3:Lerp(Theme.Colors.White, 0.12) }):Play()
	end)
	button.MouseLeave:Connect(function()
		TweenService:Create(button, TweenInfo.new(0.12), { BackgroundColor3 = color or Theme.Colors.Pink }):Play()
	end)
	button.Activated:Connect(function()
		TweenService:Create(button, TweenInfo.new(0.08), { Size = UDim2.new(1, -6, 0, Theme.TouchHeight - 3) }):Play()
		task.delay(0.09, function()
			if button.Parent then
				TweenService:Create(button, TweenInfo.new(0.1), { Size = UDim2.new(1, 0, 0, Theme.TouchHeight) }):Play()
			end
		end)
		callback()
	end)
	return button
end

function Components.list(parent, padding)
	local layout = Instance.new("UIListLayout")
	layout.Padding = UDim.new(0, padding or 10)
	layout.SortOrder = Enum.SortOrder.LayoutOrder
	layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
	layout.Parent = parent
	return layout
end

return table.freeze(Components)
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="19">
          <Properties>
            <string name="Name">Theme</string>
            <string name="Source"><![CDATA[return table.freeze({
	Colors = {
		Cream = Color3.fromRGB(255, 249, 235),
		White = Color3.fromRGB(255, 255, 255),
		Ink = Color3.fromRGB(82, 69, 88),
		Muted = Color3.fromRGB(126, 112, 132),
		Pink = Color3.fromRGB(255, 151, 187),
		PinkDark = Color3.fromRGB(224, 104, 153),
		Mint = Color3.fromRGB(139, 213, 179),
		Blue = Color3.fromRGB(139, 197, 239),
		Purple = Color3.fromRGB(190, 159, 225),
		Yellow = Color3.fromRGB(255, 218, 122),
		Red = Color3.fromRGB(229, 111, 119),
		Shadow = Color3.fromRGB(71, 53, 76),
	},
	Corner = UDim.new(0, 18),
	SmallCorner = UDim.new(0, 12),
	TouchHeight = 54,
})
]]></string>
